# Copy this file to .env and adjust as needed.
# Everything else (children, ntfy target, poll interval) is configured
# through the web UI's first-run setup wizard -- these are only the
# infrastructure-level values needed before the app can start.

# --- familylink-auth container (upstream, ghcr.io/noiwid/familylink-auth) ---
# Its image tag is pinned directly in docker-compose.yml (not via env var) so
# Dependabot can detect and propose version bumps -- see README.md's update
# runbook before merging those PRs.
# Shared secret required to read cookies from the auth container's
# /api/cookies endpoint. Generate any random string.
FAMILYLINK_AUTH_API_KEY=change-me
# Base URL our app (container-to-container) uses to reach the familylink-auth
# container. Leave as-is when using the provided docker-compose.yml.
FAMILYLINK_AUTH_BASE_URL=http://familylink-auth:8099
# Browser-facing URL for familylink-auth's noVNC login page, shown as a link
# in our app's setup wizard/status page. Use your Docker host's IP/hostname.
FAMILYLINK_AUTH_NOVNC_URL=http://localhost:6080
# Password for the noVNC web view used to complete the Google login.
VNC_PASSWORD=change-me

# --- Our app ---
# Pinned image tag for our own app -- bump deliberately, see README.md.
APP_IMAGE_TAG=latest
# Where the SQLite DB and other runtime state is stored (bind-mounted).
APP_DATA_DIR=/data
# Port the web UI/API listens on inside the container.
APP_PORT=8080
# Host port to publish our app's web UI on.
APP_HOST_PORT=8080
